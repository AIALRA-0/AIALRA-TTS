# Example Nginx site for the Contabo web control plane.
# Replace localizer.example.invalid with your public domain on the server only.
# Do not commit a production copy with a real hostname, IP, certificate path, or secret.

server {
    listen 80;
    server_name localizer.example.invalid;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name localizer.example.invalid;

    ssl_certificate /etc/letsencrypt/live/localizer.example.invalid/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/localizer.example.invalid/privkey.pem;

    client_max_body_size 1024m;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;

    location / {
        proxy_pass http://127.0.0.1:7861;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_request_buffering on;
    }
}
