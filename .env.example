# Copy to .env on the target machine. Never commit real values.

APP_ENV=local
WEBUI_HOST=127.0.0.1
WEBUI_PORT=7861

# Use deploy/bootstrap_contabo.py on Contabo to generate real values without printing secrets:
# python3 deploy/bootstrap_contabo.py --public-base-url https://your-domain.example --admin-username admin
WEBUI_SESSION_SECRET=change-me-generate-a-long-random-secret
WEBUI_DOWNLOAD_SECRET=change-me-generate-a-long-random-download-secret

# First admin account for local bootstrap only.
WEBUI_ADMIN_USERNAME=admin
WEBUI_ADMIN_PASSWORD=change-me-before-remote-use

# Contabo/remote deployment placeholders. Keep real hostnames/IPs out of git.
REMOTE_PUBLIC_BASE_URL=https://example.invalid
WORKER_TUNNEL_MODE=reverse-tunnel
# HMAC secret shared only by the Contabo web service and Windows worker.
# Worker requests use X-Worker-Timestamp + X-Worker-Nonce + X-Worker-Signature, not a plaintext token header in production.
WORKER_SHARED_TOKEN=change-me-generate-a-long-random-hmac-secret
